{
  "name": "personal-minisite-11ty",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "encrypt": "node scripts/build-private.mjs",
    "demo": "node scripts/build-private.mjs --demo --code=demo && eleventy --config=eleventy.config.cjs --serve",
    "dev": "npm run encrypt && eleventy --config=eleventy.config.cjs --serve",
    "build": "npm run encrypt && eleventy --config=eleventy.config.cjs",
    "clean": "rm -rf _site src/assets/js/private-payload.js"
  },
  "dependencies": {
    "@11ty/eleventy": "3.1.5",
    "gray-matter": "4.0.3",
    "luxon": "3.5.0",
    "markdown-it": "14.1.1"
  }
}
